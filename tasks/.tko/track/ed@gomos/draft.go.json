            "label": "2026-03-19_21-20-50",
            "content": "package main\nimport \"fmt\"\ntype Ponto struct{\n    x, y int\n}\nfunc main() {\n    var q int\n    var direcao string\n    fmt.Scan(&q, &direcao)\n\n    corpinho := make([]Ponto, q)\n    \n    for i := 0; i < q; i++{\n        fmt.Scan(&corpinho[i].x, &corpinho[i].y)\n    }\n\nposicoesanteriores := make([]Ponto, q)\ncopy(posicoesanteriores, corpinho)\n\nswitch direcao{\ncase \"U\":\n    corpinho[0].y--\ncase \"D\":\n    corpinho[0].y++\ncase \"L\":\n    corpinho[0].x--\ncase \"R\":\n    corpinho[0].x++\n}\n      \nfor i := 1; i < q; i++{        \n    corpinho[i] = posicoesanteriores[i-1]                                     \n}\n\nfor _, c := range corpinho{\n    fmt.Printf(\"%d %d\\n\", c.x, c.y)\n}\n\n}\n",
